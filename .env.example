# AI — Content generation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Supabase — optional persistence + image storage
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Meta Graph API — Instagram Business direct posting
META_ACCESS_TOKEN=          # Long-lived User Access Token (valid 60 days, refresh via FB API)
META_INSTAGRAM_BUSINESS_ID= # Instagram Business Account ID (numeric)
META_APP_ID=                # From Meta Developer App dashboard
META_APP_SECRET=            # From Meta Developer App dashboard

# Vercel Cron — weekly auto-publish authentication
CRON_SECRET=                # Any random string; set the same in Vercel Dashboard env vars
