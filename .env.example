# AI — content + image generation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Supabase — persistence + public image storage
# Required for publishing because Meta Graph API needs a public image_url.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=post-images

# Meta Graph API — Instagram Business direct publishing
# Long-lived user access token. Keep it private and refresh before expiry.
META_ACCESS_TOKEN=

# Numeric Instagram Business Account ID, not the @username.
META_INSTAGRAM_BUSINESS_ID=

# Meta Developer App credentials, used for token debug/status.
META_APP_ID=
META_APP_SECRET=

# Optional — protect future cron/automation endpoints.
CRON_SECRET=
